<main>
    <div class="text-center py-5 justify-content-center">

        <h1 class="display-4 fw-bold mb-5">Sign Up</h1>

        <form method="post" action="/signingUp" class="form-group container d-flex justify-content-center align-items-center">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" class="form-control mb-2 w-100" id="username" placeholder="Username" name="username" required="required">
                <label for="email">Email address</label>
                <input type="email" class="form-control mb-2 w-100" id="email" placeholder="Email" name="email" required="required">
                <label for="password">Password</label>
                <input type="password" class="form-control mb-2 w-100" id="password" placeholder="Password" name="password" required="required">
                <br>
                <input class="btn btn-primary" type="submit" value="Sign up">
            </div>
        </form>

    </div>
</main>