<main>
    <div class="text-center py-5 justify-content-center">

        <h1 class="display-4 fw-bold mb-5">Log In</h1>

        <form method="post" action="/loggingIn" class="form-group container d-flex justify-content-center align-items-center">
            <div class="form-group">
                <label for="email" class="mb-1">Email</label>
                <input type="email" class="form-control mb-2 w-100" id="email" placeholder="Email" name="email" required="required">
                <label for="password" class="mb-1">Password</label>
                <input type="password" class="form-control mb-2 w-100" id="password" placeholder="Password" name="password" required="required">
                <br>
                <input class="btn btn-primary" type="submit" value="Log in">
            </div>
        </form>

    </div>
</main>