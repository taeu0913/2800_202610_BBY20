<div class="text-start border-bottom py-5">

  <h1 class="display-4 fw-bold">Log In.</h1>

  <p class="lead mt-3">
    Please log in.
  </p>

  <form method="post" action="/loggingin" class="form-group">
    <div class="form-group">
        <label for="username">Username</label>
        <input type="email" class="form-control" id="username" placeholder="Username" name="username">
        <label for="email">Email address</label>
        <input type="email" class="form-control" id="email" placeholder="Email" name="email">
        <label for="password">Password</label>
        <input type="email" class="form-control" id="password" placeholder="Password" name="password">
    </div>
  </form>

</div>