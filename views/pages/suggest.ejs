<div class="row justify-content-center">
  <div class="col-md-6">
    <h2 class="mb-3">Suggest a Shading Area</h2>
    <p class="text-muted">Know a great shaded spot? Share it with the community!</p>

    <form>
      <div class="mb-3">
        <label class="form-label">Location Name</label>
        <input type="text" class="form-control" placeholder="e.g. Trout Lake Park">
      </div>

      <div class="mb-3">
        <label class="form-label">Address or Intersection</label>
        <input type="text" class="form-control" placeholder="e.g. E 15th Ave & Victoria Dr">
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea class="form-control" rows="3" placeholder="Describe the shaded area..."></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Shade Rating</label>
        <select class="form-select">
          <option>Select a rating</option>
          <option>★★★★★ Excellent</option>
          <option>★★★★☆ Good</option>
          <option>★★★☆☆ Average</option>
          <option>★★☆☆☆ Poor</option>
          <option>★☆☆☆☆ Very Poor</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Is it family friendly?</label>
        <div>
          <input type="radio" name="family" id="yes">
          <label for="yes"> Yes</label>&nbsp;&nbsp;
          <input type="radio" name="family" id="no">
          <label for="no"> No</label>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Upload a Photo (optional)</label>
        <input type="file" class="form-control">
      </div>

      <button type="submit" class="btn btn-dark w-100">Submit Location</button>
    </form>
  </div>
</div>