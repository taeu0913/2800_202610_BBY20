<div class="row justify-content-center">
  <div class="col-md-6">
    <h2 class="mb-3">Review a Shaded Area</h2>
    <p class="text-muted">Help others by sharing your experience!</p>

    <form>
      <div class="mb-3">
        <label class="form-label">Area Name</label>
        <input type="text" class="form-control" placeholder="e.g. Trout Lake Park">
      </div>

      <div class="mb-3">
        <label class="form-label">Date Visited</label>
        <input type="date" class="form-control">
      </div>

      <div class="mb-3">
        <label class="form-label">Shade Rating</label>
        <select class="form-select">
          <option>Select a rating</option>
          <option>★★★★★ Excellent</option>
          <option>★★★★☆ Good</option>
          <option>★★★☆☆ Average</option>
          <option>★★☆☆☆ Poor</option>
          <option>★☆☆☆☆ Very Poor</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">How crowded was it?</label>
        <select class="form-select">
          <option>Select crowd level</option>
          <option>Not crowded at all</option>
          <option>Slightly crowded</option>
          <option>Moderately crowded</option>
          <option>Very crowded</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Written Review</label>
        <textarea class="form-control" rows="4" placeholder="Share your experience..."></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Would you recommend it for families?</label>
        <div>
          <input type="radio" name="recommend" id="yes2">
          <label for="yes2"> Yes</label>&nbsp;&nbsp;
          <input type="radio" name="recommend" id="no2">
          <label for="no2"> No</label>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Upload a Photo (optional)</label>
        <input type="file" class="form-control">
      </div>

      <button type="submit" class="btn btn-dark w-100">Submit Review</button>
    </form>
  </div>
</div>