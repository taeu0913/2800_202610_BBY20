<div class="row justify-content-center mt-4">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">

        <div class="text-center mb-4">
          <label for="profilePicInput" style="cursor: pointer;">
            <img 
              id="profilePic"
              src="<%= user.profilePic || 'https://via.placeholder.com/80' %>"
              class="rounded-circle border"
              style="width: 80px; height: 80px; object-fit: cover;">
            <div class="mt-1">
              <small class="text-muted">Choose profile picture</small>
            </div>
          </label>
          <input 
            type="file" 
            id="profilePicInput" 
            accept="image/*" 
            style="display: none;"
            onchange="uploadImage(event)">
          <h4 class="mt-3">My Profile</h4>
        </div>

        <div class="mb-3">
          <label class="form-label text-muted">Name</label>
          <p class="form-control-plaintext fw-bold"><%= user.username %></p>
        </div>

        <div class="mb-3">
          <label class="form-label text-muted">Email</label>
          <p class="form-control-plaintext fw-bold"><%= user.email %></p>
        </div>

        <hr>

        <div class="d-grid gap-2">
          <a href="/main" class="btn btn-dark">Back to Map</a>
          <button 
            class="btn btn-danger" 
            onclick="deleteAccount()">
            Delete Account
          </button>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
function uploadImage(event) {
  const file = event.target.files[0];
  if (file) {
    const formData = new FormData();
    formData.append('profilePic', file);

    fetch('/upload-profile-pic', {
      method: 'POST',
      body: formData
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        document.getElementById('profilePic').src = data.imagePath;
      }
    })
    .catch(err => {
      alert("Failed to upload image. Please try again.");
    });
  }
}

function deleteAccount() {
  if (confirm("Are you sure you want to delete your account? This cannot be undone.")) {
    fetch('/delete-account', {
      method: 'DELETE',
    })
    .then(res => res.json())
    .then(data => {
      alert("Account deleted successfully.");
      window.location.href = '/';
    })
    .catch(err => {
      alert("Something went wrong. Please try again.");
    });
  }
}
</script>