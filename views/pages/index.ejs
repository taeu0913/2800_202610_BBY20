<% if (firstTimeUser) { %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    Welcome to ShadeFinder! Start by clicking Login or Signup.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="text-center border-bottom py-5">

  <h1 class="display-4 fw-bold">ShadeFinder</h1>

  <p class="lead mt-3">
    Stay cool, explore shaded spaces, and navigate hot days with confidence.
  </p>

  <div class="mt-4">
    <a href="/login">
      <button class="btn btn-primary btn-lg me-2"
      data-bs-toggle="tooltip" title="Login to your account">
      Login
      </button>
    </a>

    <a href="/signup">
      <button class="btn btn-outline-secondary btn-lg"
      data-bs-toggle="tooltip" title="Create a new account">
      Signup
      </button>
    </a>
  </div>

  <div class="mt-5">
    <img src="/images/landing.jpg"
      class="img-fluid rounded shadow"
      alt="ShadeFinder preview">
  </div>

</div>