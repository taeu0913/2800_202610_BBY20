<!-- Filter Section -->
<div class="filter-wrapper">

  <!-- HIGH -->
  <div class="filter-group">

    <button class="btn btn-dark rounded-pill px-3 btn-sm filter-toggle">

      High

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Maximum Shade</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Dense Trees</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- MED -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      Med

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Balanced Shade</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Mixed Routes</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- LOW -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      Low

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Shortest Route</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Open Areas</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- ADVANCED -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      <i class="bi bi-sliders"></i>

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Outdoor</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Parks</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Cooler</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Walking</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="">
  </script>

<!-- FIRST-TIME USER CALLOUT -->
<div id="welcomeCallout" class="alert alert-info alert-dismissible fade show shadow-sm m-3" role="alert">
  <h4 class="alert-heading">Welcome to ShadeFinder!</h4>

  <p>
    Use the map to discover shaded areas nearby during hot days.
    Click the map, explore shaded spots, or use your location to get started.
  </p>

  <hr>

  <p class="mb-0">
    You can also optionally contribute anonymous data to help planners design cooler urban spaces.
  </p>

  <button type="button" class="btn btn-dark mt-3" id="dismissHints">
    Got it
  </button>

  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>

<!-- FULLSCREEN MAP -->
<div id="map"></div>