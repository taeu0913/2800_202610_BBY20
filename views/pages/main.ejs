<!-- FIRST-TIME USER CALLOUT -->
<div id="welcomeCallout" class="alert alert-info alert-dismissible fade show shadow-sm m-3" role="alert">
  <h4 class="alert-heading">Welcome to ShadeFinder!</h4>

  <p>
    Use the map to discover shaded areas nearby during hot days.
    Click the map, explore shaded spots, or use your location to get started.
  </p>

  <hr>

  <p class="mb-0">
    You can also optionally contribute anonymous data to help planners design cooler urban spaces.
  </p>

  <button type="button" class="btn btn-dark mt-3" id="dismissHints">
    Got it
  </button>

  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>

<!-- filter bar -->
<div class="filter-bar">
  <button class="filter-pill active" data-type="all">All</button>
  <button class="filter-pill" data-type="tree">🌳 Trees</button>
  <button class="filter-pill" data-type="shelter">⛱ Shelter</button>
  <button class="filter-pill" data-type="park">🏞 Parks</button>
</div>

<!-- FULLSCREEN MAP -->
<div id="map"></div>

<!-- Shade Spot Modal -->
<div class="modal fade" id="shadeModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Add Shade Spot</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <input id="shadeName" class="form-control mb-2" placeholder="Name">

        <input id="shadeType" class="form-control mb-2" placeholder="Type (tree, park, shelter)">

        <input id="shadeTime" class="form-control mb-2" placeholder="Best shaded at (morning/afternoon/evening/allday)">

        <textarea id="shadeDesc" class="form-control mb-2" placeholder="Description"></textarea>

      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button id="saveShadeBtn" class="btn btn-primary">Save</button>
      </div>

    </div>
  </div>
</div>

<!-- Suggest Shade Improvement Modal -->
<div class="modal fade" id="suggestionModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Suggest Shade Improvement</h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal">
        </button>
      </div>

      <div class="modal-body">

        <select
          id="suggestCategory"
          class="form-control mb-2">

          <option value="">Select Issue</option>

          <option value="No tree coverage">
            No tree coverage
          </option>

          <option value="Bus stop lacks shelter">
            Bus stop lacks shelter
          </option>

          <option value="Playground too hot">
            Playground too hot
          </option>

          <option value="Walking path exposed">
            Walking path exposed
          </option>

          <option value="Park seating exposed">
            Park seating exposed
          </option>

          <option value="Heat island area">
            Heat island area
          </option>

        </select>

        <textarea
          id="suggestDesc"
          class="form-control"
          placeholder="Describe the issue">
        </textarea>

      </div>

      <div class="modal-footer">

        <button
          class="btn btn-secondary"
          data-bs-dismiss="modal">
          Cancel
        </button>

        <button
          id="saveSuggestionBtn"
          class="btn btn-danger">
          Submit Suggestion
        </button>

      </div>

    </div>
  </div>
</div>

<script src="/js/ai.js"></script>
<script src="/js/filters.js"></script>
<script src="/js/main.js"></script>
<script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
