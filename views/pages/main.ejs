<!-- Filter Section -->
<div class="filter-wrapper">

  <!-- HIGH -->
  <div class="filter-group">

    <button class="btn btn-dark rounded-pill px-3 btn-sm filter-toggle">

      High

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Maximum Shade</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Dense Trees</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- MED -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      Med

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Balanced Shade</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Mixed Routes</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- LOW -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      Low

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Shortest Route</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Open Areas</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>


  <!-- ADVANCED -->
  <div class="filter-group">

    <button class="btn btn-secondary rounded-pill px-3 btn-sm filter-toggle">

      <i class="bi bi-sliders"></i>

    </button>

    <div class="advanced-menu shadow">

      <div class="filter-option">

        <span>Outdoor</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Parks</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Cooler</span>

        <div class="option-line"></div>

      </div>

      <div class="filter-option">

        <span>Walking</span>

        <div class="option-line"></div>

      </div>

    </div>

  </div>

</div>

<!-- Page title (can remove later) -->
<div class="text-center mb-2">
  <h1 class="h4 fw-bold">Shade Map</h1>
</div>

<!-- FULLSCREEN MAP -->
<div id="map" style="height: calc(100vh - 120px); width: 100%;" class="border rounded">
  <div class="d-flex align-items-center justify-content-center h-100">
    <p class="text-muted m-0">Loading map...</p>
  </div>
</div>

<script src="/js/filters.js"></script>